---
import { getCollection } from "astro:content";
import Page from "@/layouts/Page.astro";
import { siteConfig } from "@/config/site";
import Card from "@/components/starwind/card/Card.astro";
import CardContent from "@/components/starwind/card/CardContent.astro";
import CardHeader from "@/components/starwind/card/CardHeader.astro";
import CardTitle from "@/components/starwind/card/CardTitle.astro";
import CardDescription from "@/components/starwind/card/CardDescription.astro";
import Badge from "@/components/starwind/badge/Badge.astro";
import Button from "@/components/starwind/button/Button.astro";
import Accordion from "@/components/starwind/accordion/Accordion.astro";
import AccordionItem from "@/components/starwind/accordion/AccordionItem.astro";
import AccordionTrigger from "@/components/starwind/accordion/AccordionTrigger.astro";
import AccordionContent from "@/components/starwind/accordion/AccordionContent.astro";

const allPages = await getCollection("coloringPages", ({ data }) => !data.draft);
const blogPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

// Hub pages: no "/" in slug (from topic/index.md files)
const hubs = allPages
  .filter((p) => !p.slug.includes("/"))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

// Hub slugs that have variants — these are excluded from the image grid
const hubSlugsWithVariants = new Set(
  allPages.filter((p) => p.slug.includes("/")).map((p) => p.slug.split("/")[0])
);

// All individual images: variants + solo hubs (no variants)
const gridPages = allPages
  .filter((p) => p.slug.includes("/") || !hubSlugsWithVariants.has(p.slug))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const difficultyVariant: Record<string, "success" | "warning" | "error"> = {
  easy: "success",
  medium: "warning",
  hard: "error",
};

const faqs = [
  {
    q: "Are these coloring pages really free?",
    a: "Yes, completely. Every coloring page on this site is free to download and print. No account, no email, no paywall — ever.",
  },
  {
    q: "How do I print a coloring page?",
    a: "Click the Download PNG button on any page, open the file, and print. All pages are formatted for standard 8.5 × 11 inch paper and print clearly on any home printer.",
  },
  {
    q: "Can I use these in my classroom?",
    a: "Absolutely. All coloring pages are free for personal and classroom use. Print as many copies as you need — no permission required.",
  },
  {
    q: "What age are these coloring pages designed for?",
    a: "We have pages for all ages. Easy designs with big, simple shapes are great for toddlers and preschoolers. More detailed pages are better suited for older kids and adults. Each page is labeled with a difficulty level to help you pick the right one.",
  },
  {
    q: "Do I need to create an account or sign up?",
    a: "No. Just find a page you like, hit download, and print. We don't require an account, email address, or any personal information.",
  },
  {
    q: "What file format are the coloring pages?",
    a: "All coloring pages are PNG files. PNG works with every printer and every device, and the files are high enough resolution to print cleanly on standard paper.",
  },
  {
    q: "Can I share these coloring pages?",
    a: "Yes. You're welcome to share links to pages on this site, or print and hand out copies for personal or educational use. Please don't re-upload the files to other sites or sell them.",
  },
  {
    q: "How often do you add new coloring pages?",
    a: "We're adding new pages regularly. New pages show up automatically at the top of each subject's page. You can also join our email newsletter — signup is in the footer — to get notified when new coloring pages are added.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map(({ q, a }) => ({
    "@type": "Question",
    name: q,
    acceptedAnswer: { "@type": "Answer", text: a },
  })),
};
---

<Page title="Free Coloring Pages to Print" description={siteConfig.description} jsonLd={faqSchema}>

  <!-- Hero -->
  <section class="mb-10">
    <h1 class="heading-1 mb-3">Free Coloring Pages to Print</h1>
    <p class="text-body max-w-2xl">
      Free printable coloring pages for kids of all ages. Every page has big, clear outlines that print well on a standard home printer — animals, holidays, characters, and more. No account or sign-up needed. Just pick a page, download, and print.
    </p>
  </section>

  <!-- Hub filter buttons -->
  <div class="mb-6 flex flex-wrap items-center gap-2">
    <span class="text-sm font-medium text-foreground">Browse by subject:</span>
    <nav class="flex flex-wrap gap-2" aria-label="Browse by subject">
      {
        hubs.map((hub) => (
          <Button
            href={`/coloring-pages/${hub.slug}`}
            variant="outline"
            size="sm"
            data-umami-event="Category Click"
            data-umami-event-category={hub.slug}
            data-umami-event-source="homepage"
          >
            {hub.data.title.replace(" Coloring Pages", "").replace(" Coloring Page", "")}
          </Button>
        ))
      }
    </nav>
  </div>

  <!-- Grid — all individual images -->
  <ul class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4" role="list">
    {
      gridPages.map((page) => (
        <li>
          <a href={`/coloring-pages/${page.slug}`} class="group block">
            <Card class="overflow-hidden transition-shadow group-hover:shadow-md" size="sm">
              <img
                src={page.data.imageUrl}
                alt={page.data.title}
                class="h-48 w-full object-contain bg-muted p-3 transition-transform group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
              <CardContent class="flex flex-col gap-2">
                <p class="text-sm font-medium text-card-foreground line-clamp-2 leading-snug">
                  {page.data.title}
                </p>
                <Badge
                  variant={difficultyVariant[page.data.difficulty]}
                  size="sm"
                  class="capitalize self-start"
                >
                  {page.data.difficulty}
                </Badge>
              </CardContent>
            </Card>
          </a>
        </li>
      ))
    }
  </ul>

  <!-- FAQ -->
  <section class="mt-16 border-t border-border pt-12">
    <h2 class="heading-4 mb-6 text-center">Frequently asked questions</h2>
    <Accordion type="single" class="max-w-2xl mx-auto">
      {faqs.map(({ q, a }, i) => (
        <AccordionItem value={`faq-${i}`}>
          <AccordionTrigger>{q}</AccordionTrigger>
          <AccordionContent>
            <p class="text-sm text-muted-foreground">{a}</p>
          </AccordionContent>
        </AccordionItem>
      ))}
    </Accordion>
  </section>

  <!-- Blog posts -->
  {
    blogPosts.length > 0 && (
      <section class="mt-16 border-t border-border pt-12">
        <div class="mb-6 flex items-center justify-between">
          <h2 class="heading-4">From the Blog</h2>
          <a href="/blog" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
            All posts →
          </a>
        </div>
        <ul class="grid gap-4 sm:grid-cols-2">
          {blogPosts.map((post) => (
            <li>
              <a href={`/blog/${post.slug}`} class="group block">
                <Card class="transition-shadow group-hover:shadow-md">
                  <CardHeader>
                    <p class="text-caption">
                      {post.data.pubDate.toLocaleDateString("en-US", {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                      })}
                    </p>
                    <CardTitle class="group-hover:text-primary transition-colors">
                      {post.data.title}
                    </CardTitle>
                    <CardDescription>{post.data.description}</CardDescription>
                  </CardHeader>
                </Card>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }

</Page>
