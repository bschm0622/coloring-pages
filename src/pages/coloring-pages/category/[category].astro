---
import { getCollection } from "astro:content";
import Page from "@/layouts/Page.astro";
import Breadcrumb from "@/components/starwind/breadcrumb/Breadcrumb.astro";
import BreadcrumbList from "@/components/starwind/breadcrumb/BreadcrumbList.astro";
import BreadcrumbItem from "@/components/starwind/breadcrumb/BreadcrumbItem.astro";
import BreadcrumbLink from "@/components/starwind/breadcrumb/BreadcrumbLink.astro";
import BreadcrumbSeparator from "@/components/starwind/breadcrumb/BreadcrumbSeparator.astro";
import BreadcrumbPage from "@/components/starwind/breadcrumb/BreadcrumbPage.astro";
import Card from "@/components/starwind/card/Card.astro";
import CardContent from "@/components/starwind/card/CardContent.astro";
import Badge from "@/components/starwind/badge/Badge.astro";

export async function getStaticPaths() {
  const allPages = await getCollection("coloringPages", ({ data }) => !data.draft);
  const categories = [...new Set(allPages.map((p) => p.data.category))];

  return categories.map((category) => ({
    params: { category: category.toLowerCase().replace(/\s+/g, "-") },
    props: {
      categoryName: category,
      pages: allPages
        .filter((p) => p.data.category === category)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { categoryName, pages } = Astro.props;

const difficultyVariant: Record<string, "success" | "warning" | "error"> = {
  easy: "success",
  medium: "warning",
  hard: "error",
};
---

<Page
  title={`${categoryName} Coloring Pages`}
  description={`Free printable ${categoryName.toLowerCase()} coloring pages for kids and adults. Download and print ${pages.length} free ${categoryName.toLowerCase()} coloring sheets.`}
>
  <!-- Breadcrumb -->
  <Breadcrumb class="mb-6">
    <BreadcrumbList>
      <BreadcrumbItem>
        <BreadcrumbLink href="/">Coloring Pages</BreadcrumbLink>
      </BreadcrumbItem>
      <BreadcrumbSeparator />
      <BreadcrumbItem>
        <BreadcrumbPage>{categoryName}</BreadcrumbPage>
      </BreadcrumbItem>
    </BreadcrumbList>
  </Breadcrumb>

  <div class="mb-8">
    <h1 class="heading-2">{categoryName} Coloring Pages</h1>
    <p class="text-lead mt-2">
      {pages.length} free printable {categoryName.toLowerCase()} coloring pages. Click any image to download.
    </p>
  </div>

  <ul class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4" role="list">
    {
      pages.map((page) => (
        <li>
          <a href={`/coloring-pages/${page.slug}`} class="group block">
            <Card class="overflow-hidden transition-shadow group-hover:shadow-md" size="sm">
              <img
                src={page.data.imageUrl}
                alt={page.data.title}
                class="h-48 w-full object-contain bg-muted p-3 transition-transform group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
              <CardContent class="flex flex-col gap-2">
                <p class="text-sm font-medium text-card-foreground line-clamp-2 leading-snug">
                  {page.data.title}
                </p>
                <div class="flex items-center justify-between gap-2">
                  <span class="text-caption">{page.data.category}</span>
                  <Badge
                    variant={difficultyVariant[page.data.difficulty]}
                    size="sm"
                    class="capitalize"
                  >
                    {page.data.difficulty}
                  </Badge>
                </div>
              </CardContent>
            </Card>
          </a>
        </li>
      ))
    }
  </ul>
</Page>
