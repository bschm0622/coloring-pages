---
import { getCollection } from "astro:content";
import Page from "@/layouts/Page.astro";
import { siteConfig } from "@/config/site";
import Breadcrumb from "@/components/starwind/breadcrumb/Breadcrumb.astro";
import BreadcrumbList from "@/components/starwind/breadcrumb/BreadcrumbList.astro";
import BreadcrumbItem from "@/components/starwind/breadcrumb/BreadcrumbItem.astro";
import BreadcrumbLink from "@/components/starwind/breadcrumb/BreadcrumbLink.astro";
import BreadcrumbSeparator from "@/components/starwind/breadcrumb/BreadcrumbSeparator.astro";
import BreadcrumbPage from "@/components/starwind/breadcrumb/BreadcrumbPage.astro";
import Button from "@/components/starwind/button/Button.astro";
import Badge from "@/components/starwind/badge/Badge.astro";
import Card from "@/components/starwind/card/Card.astro";
import CardContent from "@/components/starwind/card/CardContent.astro";
import EmailPopup from "@/components/EmailPopup.astro";
import Prose from "@/components/starwind/prose/Prose.astro";

export async function getStaticPaths() {
  const allPages = await getCollection("coloringPages", ({ data }) => !data.draft);
  const hubPages = allPages.filter((p) => !p.slug.includes("/"));
  const variantPages = allPages.filter((p) => {
    const parts = p.slug.split("/");
    return parts.length === 2 && parts[1] !== "index";
  });

  return variantPages.map((page) => {
    const [topic, variant] = page.slug.split("/");
    const related = allPages
      .filter((p) => p.slug.startsWith(topic + "/") && p.slug !== page.slug)
      .slice(0, 4);
    const suggestedHubs = hubPages
      .filter((h) => h.slug !== topic)
      .slice(0, 4);
    return {
      params: { topic, variant },
      props: { page, topic, related, suggestedHubs },
    };
  });
}

const { page, topic, related, suggestedHubs } = Astro.props;
const { data } = page;
const { Content } = await page.render();

const difficultyVariant: Record<string, "success" | "warning" | "error"> = {
  easy: "success",
  medium: "warning",
  hard: "error",
};

const hubTitle = topic.split("-").map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(" ") + " Coloring Pages";

const { variant } = Astro.params;
const pageUrl = `${siteConfig.url}/coloring-pages/${topic}/${variant}`;
const imageUrl = `${siteConfig.url}${data.imageUrl}`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    name: data.title,
    description: data.description,
    url: pageUrl,
    image: { "@type": "ImageObject", url: imageUrl, encodingFormat: "image/png" },
    isAccessibleForFree: true,
    keywords: data.tags.join(", "),
    audience: { "@type": "Audience", audienceType: "children" },
    datePublished: data.pubDate.toISOString(),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Coloring Pages", item: `${siteConfig.url}/` },
      { "@type": "ListItem", position: 2, name: hubTitle, item: `${siteConfig.url}/coloring-pages/${topic}` },
      { "@type": "ListItem", position: 3, name: data.title },
    ],
  },
];
---

<Page title={data.title} description={data.description} ogImage={data.imageUrl} jsonLd={jsonLd}>
  <!-- Breadcrumb -->
  <Breadcrumb class="mb-6">
    <BreadcrumbList>
      <BreadcrumbItem>
        <BreadcrumbLink href="/">Coloring Pages</BreadcrumbLink>
      </BreadcrumbItem>
      <BreadcrumbSeparator />
      <BreadcrumbItem>
        <BreadcrumbLink href={`/coloring-pages/${topic}`}>{hubTitle}</BreadcrumbLink>
      </BreadcrumbItem>
      <BreadcrumbSeparator />
      <BreadcrumbItem>
        <BreadcrumbPage>{data.title}</BreadcrumbPage>
      </BreadcrumbItem>
    </BreadcrumbList>
  </Breadcrumb>

  <div class="grid gap-8 lg:grid-cols-[1fr_280px]">
    <!-- Image -->
    <div>
      <div class="rounded-lg border border-border bg-muted p-4 shadow-sm">
        <img
          src={data.imageUrl}
          alt={data.title}
          class="mx-auto block max-h-150 w-full object-contain"
          loading="eager"
          fetchpriority="high"
        />
      </div>

      <!-- Download buttons -->
      <div class="mt-4 flex gap-3">
        {data.pdfUrl ? (
          <>
            <Button href={data.pdfUrl} download variant="primary" size="lg" class="flex-1 justify-center gap-2" data-umami-event="Download PDF" data-umami-event-title={data.title} data-umami-event-topic={topic}>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              Download PDF
            </Button>
            <Button href={data.imageUrl} download variant="outline" class="flex-1 justify-center gap-2" data-umami-event="Download PNG" data-umami-event-title={data.title} data-umami-event-topic={topic}>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              Download PNG
            </Button>
          </>
        ) : (
          <Button href={data.imageUrl} download variant="primary" size="lg" class="flex-1 justify-center gap-2" data-umami-event="Download PNG" data-umami-event-title={data.title} data-umami-event-topic={topic}>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
            Download PNG
          </Button>
        )}
      </div>

      <!-- Body text -->
      <Prose class="mt-8 max-w-none">
        <Content />
      </Prose>
    </div>

    <!-- Sidebar -->
    <aside class="space-y-6">
      <div>
        <h1 class="heading-3">{data.title}</h1>
        <p class="text-lead mt-2">{data.description}</p>
      </div>

      <dl class="space-y-3 text-sm">
        <div class="flex items-center justify-between border-b border-border pb-3">
          <dt class="text-caption">Difficulty</dt>
          <dd>
            <Badge variant={difficultyVariant[data.difficulty]} size="sm" class="capitalize">
              {data.difficulty}
            </Badge>
          </dd>
        </div>
        <div class="flex items-center justify-between border-b border-border pb-3">
          <dt class="text-caption">Format</dt>
          <dd class="font-medium text-foreground">PNG {data.pdfUrl ? "+ PDF" : ""}</dd>
        </div>
      </dl>

      {
        data.tags.length > 0 && (
          <div>
            <p class="text-caption mb-2">Tags</p>
            <div class="flex flex-wrap gap-2">
              {data.tags.map((tag) => (
                <Badge variant="secondary" size="sm" class="capitalize px-3 py-1">
                  {tag}
                </Badge>
              ))}
            </div>
          </div>
        )
      }

      <div class="rounded-lg border border-border bg-muted p-4 text-sm text-muted-foreground">
        <p class="font-medium text-foreground mb-1">Free to print & share</p>
        <p>All coloring pages are free to download and print for personal and classroom use.</p>
      </div>
    </aside>
  </div>

  <!-- More from this topic -->
  {
    related.length > 0 && (
      <section class="mt-12 border-t border-border pt-10">
        <h2 class="heading-4 mb-6">
          More <a href={`/coloring-pages/${topic}`} class="hover:text-primary transition-colors">{hubTitle}</a>
        </h2>
        <ul class="grid grid-cols-2 gap-4 sm:grid-cols-4">
          {related.map((p) => {
            const [t, v] = p.slug.split("/");
            return (
              <li>
                <a href={`/coloring-pages/${t}/${v}`} class="group block">
                  <Card class="overflow-hidden transition-shadow group-hover:shadow-md" size="sm">
                    <img
                      src={p.data.imageUrl}
                      alt={p.data.title}
                      class="h-32 w-full object-contain bg-muted p-2 transition-transform group-hover:scale-105"
                      loading="lazy"
                      decoding="async"
                    />
                    <CardContent>
                      <p class="text-xs font-medium text-card-foreground line-clamp-2">
                        {p.data.title}
                      </p>
                    </CardContent>
                  </Card>
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    )
  }

  <!-- Explore more subjects -->
  {suggestedHubs.length > 0 && (
    <section class="mt-12 border-t border-border pt-10">
      <h2 class="heading-4 mb-6">Explore more coloring pages</h2>
      <ul class="grid grid-cols-2 gap-4 sm:grid-cols-4" role="list">
        {suggestedHubs.map((hub) => (
          <li>
            <a href={`/coloring-pages/${hub.slug}`} class="group block">
              <Card class="overflow-hidden transition-shadow group-hover:shadow-md" size="sm">
                <img
                  src={hub.data.imageUrl}
                  alt={hub.data.title}
                  class="h-32 w-full object-contain bg-muted p-2 transition-transform group-hover:scale-105"
                  loading="lazy"
                  decoding="async"
                />
                <CardContent>
                  <p class="text-xs font-medium text-card-foreground line-clamp-2">
                    {hub.data.title}
                  </p>
                </CardContent>
              </Card>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <EmailPopup />
</Page>
