---
// Search modal — Fuse.js loaded lazily when modal opens
---

<div data-search-root>
  <button
    data-search-trigger
    aria-label="Search coloring pages"
    class="flex items-center gap-2 rounded-md border border-accent-foreground/30 bg-accent-foreground/10 px-3 py-1.5 text-sm text-accent-foreground transition-colors hover:bg-accent-foreground/20"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.3-4.3"></path>
    </svg>
    <span>Search</span>
  </button>

  <!-- Overlay -->
  <div
    data-search-overlay
    class="fixed inset-0 z-50 hidden bg-black/50 p-4"
    role="dialog"
    aria-modal="true"
    aria-label="Search"
  >
    <div class="mx-auto mt-16 max-w-xl rounded-lg border border-border bg-background shadow-xl">
      <div class="flex items-center gap-3 border-b border-border px-4 py-3">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="shrink-0 text-muted-foreground"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <input
          data-search-input
          type="search"
          placeholder="Search coloring pages..."
          autocomplete="off"
          class="flex-1 bg-transparent text-sm text-foreground outline-none placeholder:text-muted-foreground"
        />
        <button
          data-search-close
          aria-label="Close search"
          class="text-muted-foreground hover:text-foreground"
        >
          <kbd class="rounded border border-border px-1 text-xs">Esc</kbd>
        </button>
      </div>
      <ul
        data-search-results
        class="max-h-72 overflow-y-auto p-2 empty:hidden"
        role="listbox"
        aria-label="Search results"
      >
      </ul>
      <p
        data-search-empty
        class="hidden px-4 py-6 text-center text-sm text-muted-foreground"
      >
        No results found.
      </p>
    </div>
  </div>
</div>

<script>
  let fuse: any = null;

  async function loadFuse(input: HTMLInputElement) {
    if (fuse) return;
    try {
      const [{ default: Fuse }, res] = await Promise.all([
        import("fuse.js"),
        fetch("/search.json"),
      ]);
      const data = await res.json();
      fuse = new Fuse(data, {
        keys: ["title", "tags", "description"],
        threshold: 0.2,
        ignoreLocation: true,
      });
      if (input.value.trim()) input.dispatchEvent(new Event("input"));
    } catch (e) {
      console.error("Search failed to load:", e);
    }
  }

  document.querySelectorAll("[data-search-root]").forEach((root) => {
    const trigger = root.querySelector("[data-search-trigger]")!;
    const overlay = root.querySelector("[data-search-overlay]") as HTMLElement;
    const input = root.querySelector("[data-search-input]") as HTMLInputElement;
    const resultsList = root.querySelector("[data-search-results]")!;
    const emptyMsg = root.querySelector("[data-search-empty]")!;
    const closeBtn = root.querySelector("[data-search-close]")!;

    function openModal() {
      overlay.classList.remove("hidden");
      input.focus();
      loadFuse(input);
    }

    function closeModal() {
      overlay.classList.add("hidden");
      input.value = "";
      resultsList.innerHTML = "";
      emptyMsg.classList.add("hidden");
    }

    trigger.addEventListener("click", openModal);
    closeBtn.addEventListener("click", closeModal);

    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) closeModal();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !overlay.classList.contains("hidden")) closeModal();
    });

    input.addEventListener("input", () => {
      const query = input.value.trim();

      if (!query || !fuse) {
        resultsList.innerHTML = "";
        emptyMsg.classList.add("hidden");
        return;
      }

      const results = fuse.search(query).slice(0, 8);

      if (results.length === 0) {
        resultsList.innerHTML = "";
        emptyMsg.classList.remove("hidden");
        return;
      }

      emptyMsg.classList.add("hidden");
      resultsList.innerHTML = results
        .map(
          ({ item }: { item: any }) => `
          <li role="option">
            <a
              href="${item.url}"
              class="flex flex-col gap-0.5 rounded-md px-3 py-2 hover:bg-accent hover:text-accent-foreground"
            >
              <span class="text-sm font-medium text-foreground">${item.title}</span>
              <span class="text-xs text-muted-foreground line-clamp-1">${item.description}</span>
            </a>
          </li>
        `
        )
        .join("");
    });
  });
</script>
