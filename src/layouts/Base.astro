---
import SEO from "@/components/seo/SEO.astro";
import "@/styles/starwind.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  pubDate?: Date;
  updatedDate?: Date;
  type?: "website" | "article";
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, ogImage, pubDate, updatedDate, type, noindex, jsonLd } =
  Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400;1,9..40,500&display=swap" rel="stylesheet" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      pubDate={pubDate}
      updatedDate={updatedDate}
      type={type}
      noindex={noindex}
      jsonLd={jsonLd}
    />
    <slot name="head" />
    <script defer src="https://cloud.umami.is/script.js" data-website-id="85429187-6ce6-470a-9e62-1a12d07a585a" data-domains="findcoloringpages.com"></script>
  </head>
  <body>
    <slot />
  </body>
</html>
