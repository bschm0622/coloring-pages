---
import Container from "@/components/ui/Container.astro";
import StarwindProse from "@/components/starwind/prose/Prose.astro";
import Page from "./Page.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  ogImage?: string;
}

const { title, description, pubDate, updatedDate, tags = [], ogImage } =
  Astro.props;

const readingTime = null; // populated via remark plugin if added later
---

<Page
  title={title}
  description={description}
  ogImage={ogImage}
  type="article"
  pubDate={pubDate}
  updatedDate={updatedDate}
>
  <Container prose tag="article">
    <header class="mb-8">
      <h1 class="heading-2 mb-3">
        {title}
      </h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-muted-foreground">
        <time datetime={pubDate.toISOString()}>
          {
            pubDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </time>
        {
          updatedDate && (
            <span>
              &middot; Updated{" "}
              <time datetime={updatedDate.toISOString()}>
                {updatedDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
            </span>
          )
        }
        {
          tags.length > 0 && (
            <div class="flex flex-wrap gap-1">
              {tags.map((tag) => (
                <span class="rounded-full bg-secondary px-2 py-0.5 text-xs text-secondary-foreground">
                  {tag}
                </span>
              ))}
            </div>
          )
        }
      </div>
    </header>

    <StarwindProse class="max-w-none">
      <slot />
    </StarwindProse>
  </Container>
</Page>
